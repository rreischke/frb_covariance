
m_nu_chains = []
m_nu_chains_names = []
m_nu_chains_parameters = []


file_name = "./../chains/output_nautilus_B_m_nu_lcdm.txt"
m_nu_chains.append(np.array(np.loadtxt(file_name)))
m_nu_chains_names.append(r"$\mathrm{Legacy}$")
